{
  "autoUpdatesChannel": "latest",
  "permissions": {
    "defaultMode": "bypassPermissions"
  },
  "effortLevel": "medium",
  "extraKnownMarketplaces": {
    "anthropic-agent-skills": {
      "source": {
        "repo": "anthropics/skills",
        "source": "github"
      }
    },
    "claude-plugins-official": {
      "source": {
        "repo": "anthropics/claude-plugins-official",
        "source": "github"
      }
    }
  },
  "skipDangerousModePermissionPrompt": true,
  "agentPushNotifEnabled": true,
  "enabledPlugins": {
    "document-skills@anthropic-agent-skills": true,
    "playwright@claude-plugins-official": true
  },
  "remoteControlAtStartup": false,
  "hooks": {
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "powershell.exe -NoProfile -Sta -ExecutionPolicy Bypass -File \"$env:USERPROFILE\\.claude\\toast.ps1\"",
            "async": true,
            "shell": "powershell"
          }
        ]
      }
    ]
  },
  "statusLine": {
    "command": "powershell.exe -NoProfile -NonInteractive -ExecutionPolicy Bypass -Command \"& (Join-Path $env:USERPROFILE '.claude\\statusline.ps1')\"",
    "type": "command"
  }
}
