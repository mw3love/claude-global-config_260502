#!/bin/bash
# post-commit hook: README에 변경 이력 자동 추가

LAST_MSG=$(git log -1 --pretty=%s)
if [[ "$LAST_MSG" == "docs: 변경 이력"* ]]; then
    exit 0
fi

export DATE=$(date +"%Y-%m-%d")
export PC=$(hostname)
export COMMIT_MSG=$(git log -1 --pretty="%s")

python - <<'PYEOF'
import re, os
date = os.environ['DATE']
pc   = os.environ['PC']
msg  = os.environ['COMMIT_MSG'].replace('|', '/')

with open('README.md', encoding='utf-8') as f:
    content = f.read()

new_row = f'| {date} | {pc} | {msg} |'
content = re.sub(
    r'(\| 날짜 \| PC \| 커밋 메시지 \|\n\|[-| ]+\|)',
    r'\1\n' + new_row,
    content
)

with open('README.md', 'w', encoding='utf-8') as f:
    f.write(content)
PYEOF

git add README.md
git commit -m "docs: 변경 이력 업데이트 ($PC)"

exit 0
