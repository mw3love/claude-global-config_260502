#!/bin/bash
# post-merge hook: settings.json의 statusLine 경로를 현재 PC 프로필 폴더로 자동 교체
# USERNAME != USERPROFILE 폴더명인 경우를 대비해 USERPROFILE 기준으로 처리

USERPROFILE_PATH=$(powershell.exe -NoProfile -NonInteractive -Command '$env:USERPROFILE.Replace("\", "/")' 2>/dev/null | tr -d '\r\n')

if [ -z "$USERPROFILE_PATH" ]; then
    echo "[post-merge] USERPROFILE를 가져올 수 없어 statusLine 경로 업데이트를 건너뜁니다."
    exit 0
fi

export PATCH_USERPROFILE="$USERPROFILE_PATH"
export PATCH_SETTINGS="$USERPROFILE_PATH/.claude/settings.json"

python - <<'PYEOF'
import sys, json, re, os

userprofile = os.environ['PATCH_USERPROFILE']  # e.g. C:/Users/7make
settings_path = os.environ['PATCH_SETTINGS']

folder_name = userprofile.rstrip('/').split('/')[-1]  # e.g. 7make

try:
    with open(settings_path, encoding='utf-8') as f:
        data = json.load(f)
except Exception as e:
    print(f"[post-merge] settings.json 읽기 실패: {e}")
    sys.exit(0)

old_cmd = data.get('statusLine', {}).get('command', '')

new_cmd = re.sub(
    r'C:\\Users\\[^\\]+\\\.claude\\statusline\.ps1',
    rf'C:\\Users\\{folder_name}\\.claude\\statusline.ps1',
    old_cmd
)

if new_cmd == old_cmd:
    sys.exit(0)

data['statusLine']['command'] = new_cmd

with open(settings_path, 'w', encoding='utf-8') as f:
    json.dump(data, f, indent=2, ensure_ascii=False)
    f.write('\n')

print("UPDATED")
PYEOF

if ! git diff --quiet settings.json 2>/dev/null; then
    PC=$(hostname | tr -d '\r\n')
    git add settings.json
    git commit -m "chore: statusLine 경로 로컬 적용 ($PC)"
fi

exit 0
